# GEMINI AI API (from google ai studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Connect to Supabase via connection pooling (Port 6543)
# Tip: Remember to add ?pgbouncer=true at the end of this link
DATABASE_URL=postgresql://postgres:password@host:6543/postgres?pgbouncer=true

# Direct connection to the database (Port 5432). Used for migrations.
DIRECT_URL=postgresql://postgres:password@host:5432/postgres

# NextAuth Secret (Generate via: openssl rand -base64 32)
NEXTAUTH_SECRET=your_generated_secret_here

# Base site URL (Keep as localhost for development)
NEXTAUTH_URL=http://localhost:3000