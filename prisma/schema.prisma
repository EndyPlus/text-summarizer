

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
  posts SummarizedText[]
}

model SummarizedText {
  id        Int     @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now()) 
  authorId  Int
  author    User    @relation(fields: [authorId], references: [id])
}